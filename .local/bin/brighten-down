#!/bin/bash

MIN=960
MAX=$(brightnessctl max)
CURR=$(brightnessctl get)

if (($CURR <= $MIN)); then
  brightnessctl set 0
  icedshell osd bright 0 dec
else
  if (($CURR <= 9600)); then
    brightnessctl set 1%
  else
    brightnessctl set 10-%
  fi

  CURR=$(brightnessctl get)
  PER=$(awk "BEGIN { pc=100*${CURR}/${MAX}; i=int(pc); print (pc-i<0.5)?i:i+1 }")
  icedshell osd bright $PER dec
fi
